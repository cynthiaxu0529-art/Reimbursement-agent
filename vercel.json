{
  "framework": "nextjs",
  "buildCommand": "node scripts/migrate.js && npm run build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/update-monthly-rates",
      "schedule": "5 0 1 * *"
    },
    {
      "path": "/api/cron/auto-approval",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/auto-payment",
      "schedule": "*/15 * * * *"
    }
  ]
}
